#Backend port
PORT=4000
HOST=0.0.0.0
PASSWORD=admin
#Backend API
VITE_API_URL=http://localhost:4000
#Google Cloud Agent Config
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_API_KEY=your_google_cloud_agent_api_key
AGENT_MODEL=gemini-3.1-flash-lite
#SQLLite Config
ENCRYPTION_KEY=your_encryption_key_32_characters_here!
#Node environment
NODE_ENV=development
#Backend Config

#Arize Phoenix Telemetry refs:https://arize.com/docs/phoenix/tracing/how-to-tracing/setup-tracing/setup-using-phoenix-otel#configuration-options-1
# Mode 1 – Arize Cloud: set ARIZE_SPACE_ID + PHOENIX_API_KEY + endpoint to https://app.phoenix.arize.com/s/your-space-name
# Mode 2 – Local Phoenix: pip install arize-phoenix && python -m phoenix.server.main serve
PHOENIX_PROJECT_NAME=vibe-mongo-admin
# Phoenix Cloud
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
# Local (default, no API key required)
# PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006"
PHOENIX_API_KEY=your_arize_api_key
